DB_HOST=localhost
DB_USER=root
DB_PASSWORD=
DB_NAME=myappdb
DB_PORT=3306
DB_CONNECTION_LIMIT=10
DB_MAX_IDLE=10
DB_IDLE_TIMEOUT_MS=60000
DB_QUEUE_LIMIT=0

NODE_ENV=development
PORT=3000
AUTH_TOKEN_SECRET=replace-with-at-least-32-random-characters
AUTH_TOKEN_TTL_SECONDS=604800
ALLOW_LEGACY_USER_HEADER=true
LOG_LEVEL=info
ACTIVITY_CACHE_TTL_MS=30000
OPS_API_TOKEN=replace-with-a-random-operations-token
ADMIN_EMAILS=admin@example.com

CRAWLER_USER_AGENT=kkiri-kkiri-crawler/1.0 (+https://github.com/C4t4ddict/kkiri-kkiri)
CRAWLER_REQUEST_DELAY_MS=1000
CRAWLER_TIMEOUT_MS=15000
CRAWLER_RETRIES=3
CRAWLER_RESPECT_ROBOTS=true
CRAWLER_PAGES=3
CRAWLER_LIMIT=50
CRAWLER_AUTO_ENABLED=true
CRAWLER_AUTO_INTERVAL_HOURS=6
CRAWLER_AUTO_INITIAL_DELAY_SECONDS=30
